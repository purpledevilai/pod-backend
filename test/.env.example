# Copy this file to .env and fill in your actual values

# API Configuration
API_URL=https://your-api-gateway-url.amazonaws.com/prod

# Test Email (use a real email you can access for verification tests)
TEST_EMAIL=your-test-email@example.com

# JWT Secret (optional, for advanced testing scenarios)
JWT_SECRET=your-jwt-secret-here

# Test Access Token (optional, for authenticated endpoint tests)
# Get this by creating a test account and completing the verification flow
TEST_ACCESS_TOKEN=your-access-token-here
